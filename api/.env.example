# Copie para .env na raiz ou em api/ (não commite segredos).
# Render: use Environment Group / variáveis do serviço.

AUTH_JWT_SECRET=
DATABASE_URL=
RESEND_API_KEY=
RESEND_FROM=Radar Exynax <login@auth.radarexynax.com>
RESEND_REPLY_TO=
DOMAIN_ID=

# Site estático (link register.html no e-mail de convite)
PUBLIC_SITE_URL=https://www.radarexynax.com

# URL pública desta API (magic link → GET /auth/confirm)
PUBLIC_API_URL=https://exynax-api-soberana.onrender.com

# Opcional: origens extra CORS, separadas por vírgula
# CORS_ORIGINS=
